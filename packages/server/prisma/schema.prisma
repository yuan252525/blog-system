generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String             @id @default(uuid())
  username           String             @unique
  email              String             @unique
  passwordHash       String             @map("password_hash")
  avatar             String?
  bio                String?
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")
  posts              Post[]
  comments           Comment[]
  likes              Like[]
  commentLikes       CommentLike[]
  notifications      Notification[]     @relation("NotificationRecipient")
  actorNotifications Notification[]     @relation("NotificationActor")
  chatMessages       ChatMessage[]
  chatMentions       ChatMention[]
  chatMessageReactions ChatMessageReaction[]
  chatRoomMembers    ChatRoomMember[]
  createdChatRooms   ChatRoom[]         @relation("ChatRoomCreator")
  moments            Moment[]
  momentLikes        MomentLike[]
  momentComments     MomentComment[]    @relation("MomentCommentAuthor")
  momentCommentReplies MomentComment[]  @relation("MomentCommentReplyTo")

  // ===== 成长体系（积分 / 等级 / 签到）=====
  points            Int         @default(0) @map("points")
  level             Int         @default(1) @map("level")
  lastCheckIn       DateTime?   @map("last_check_in")
  checkInStreak     Int         @default(0) @map("check_in_streak")
  checkIns          CheckIn[]
  badges            UserBadge[]

  // ===== 关注关系 =====
  followers         Follow[]        @relation("Following")
  following         Follow[]        @relation("Follower")

  @@map("users")
}

model Notification {
  id        String   @id @default(uuid())
  type      String
  message   String
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")
  userId    String   @map("user_id")
  actorId   String   @map("actor_id")
  postId    String?  @map("post_id")
  commentId String?  @map("comment_id")
  momentId  String?  @map("moment_id")
  user      User     @relation("NotificationRecipient", fields: [userId], references: [id], onDelete: Cascade)
  actor     User     @relation("NotificationActor", fields: [actorId], references: [id], onDelete: Cascade)
  post      Post?    @relation(fields: [postId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt(sort: Desc)])
  @@index([actorId])
  @@map("notifications")
}

model Post {
  id            String         @id @default(uuid())
  title         String
  slug          String         @unique
  content       String
  summary       String?
  coverImage    String?        @map("cover_image")
  pdfUrl        String?        @map("pdf_url")
  status        PostStatus     @default(DRAFT)
  viewCount     Int            @default(0) @map("view_count")
  publishedAt   DateTime?      @map("published_at")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  authorId      String         @map("author_id")
  categoryId    String?        @map("category_id")
  author        User           @relation(fields: [authorId], references: [id], onDelete: Cascade)
  category      Category?      @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  tags          PostTag[]
  comments      Comment[]
  likes         Like[]
  notifications Notification[]

  @@index([authorId])
  @@index([categoryId])
  @@index([status, publishedAt(sort: Desc)])
  @@map("posts")
}

model Tag {
  id    String    @id @default(uuid())
  name  String
  slug  String    @unique
  posts PostTag[]

  @@map("tags")
}

model PostTag {
  postId String @map("post_id")
  tagId  String @map("tag_id")
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
  @@map("post_tags")
}

enum PostStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model Upload {
  id            String        @id @default(uuid())
  filename      String
  mimeType      String
  totalSize     BigInt
  totalChunks   Int
  uploadedBytes BigInt        @default(0)
  status        UploadStatus  @default(PENDING)
  userId        String        @map("user_id")
  objectKey     String?       @map("object_key")
  url           String?       @map("url")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")
  chunks        UploadChunk[]

  @@index([userId, status])
  @@map("uploads")
}

model UploadChunk {
  id         String  @id @default(uuid())
  uploadId   String  @map("upload_id")
  chunkIndex Int     @map("chunk_index")
  size       BigInt
  hash       String
  uploaded   Boolean @default(false)
  upload     Upload  @relation(fields: [uploadId], references: [id], onDelete: Cascade)

  @@unique([uploadId, chunkIndex])
  @@map("upload_chunks")
}

enum UploadStatus {
  PENDING
  UPLOADING
  COMPLETED
  FAILED
  CANCELLED
}

model Category {
  id          String   @id @default(uuid())
  name        String   @unique
  slug        String   @unique
  description String?
  postCount   Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")
  posts       Post[]

  @@map("categories")
}

model Comment {
  id        String        @id @default(uuid())
  content   String
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")
  postId    String        @map("post_id")
  userId    String        @map("user_id")
  parentId  String?       @map("parent_id")
  post      Post          @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent    Comment?      @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   Comment[]     @relation("CommentReplies")
  likes     CommentLike[]

  @@index([postId, createdAt])
  @@index([userId])
  @@map("comments")
}

model Like {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now()) @map("created_at")
  postId    String   @map("post_id")
  userId    String   @map("user_id")
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@map("likes")
}

model CommentLike {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now()) @map("created_at")
  commentId String   @map("comment_id")
  userId    String   @map("user_id")
  comment   Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId])
  @@map("comment_likes")
}

// ========== 聊天室 ==========

enum RoomType {
  GROUP
  DIRECT
}

enum MessageType {
  TEXT
  IMAGE
  FILE
  SYSTEM
}

model ChatRoom {
  id          String            @id @default(uuid())
  name        String
  description String?
  type        RoomType          @default(GROUP)
  createdById String            @map("created_by_id")
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")
  createdBy   User              @relation("ChatRoomCreator", fields: [createdById], references: [id], onDelete: Cascade)
  members     ChatRoomMember[]
  messages    ChatMessage[]

  @@index([updatedAt(sort: Desc)])
  @@map("chat_rooms")
}

model ChatRoomMember {
  id         String    @id @default(uuid())
  roomId     String    @map("room_id")
  userId     String    @map("user_id")
  joinedAt   DateTime  @default(now()) @map("joined_at")
  lastReadAt DateTime? @map("last_read_at")
  room       ChatRoom  @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([roomId, userId])
  @@index([userId])
  @@map("chat_room_members")
}

model ChatMessage {
  id        String        @id @default(uuid())
  content   String
  type      MessageType   @default(TEXT)
  fileUrl   String?       @map("file_url")
  fileName  String?       @map("file_name")
  fileSize  BigInt?       @map("file_size")
  mimeType  String?       @map("mime_type")
  roomId    String        @map("room_id")
  userId    String        @map("user_id")
  createdAt DateTime      @default(now()) @map("created_at")
  room      ChatRoom      @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  mentions  ChatMention[]
  reactions ChatMessageReaction[]

  @@index([roomId, createdAt(sort: Desc)])
  @@index([userId])
  @@map("chat_messages")
}

model ChatMessageReaction {
  id        String   @id @default(uuid())
  messageId String   @map("message_id")
  userId    String   @map("user_id")
  type      String   @map("type") // 'LIKE' | 'CHEER'
  createdAt DateTime @default(now()) @map("created_at")
  message   ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, type])
  @@index([messageId])
  @@map("chat_message_reactions")
}

model ChatMention {
  id        String      @id @default(uuid())
  messageId String      @map("message_id")
  userId    String      @map("user_id")
  message   ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@map("chat_mentions")
}

// ========== 朋友圈（Moments） ==========

model Moment {
  id        String           @id @default(uuid())
  content   String
  images    String[]
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")
  authorId  String           @map("author_id")
  author    User             @relation(fields: [authorId], references: [id], onDelete: Cascade)
  likes     MomentLike[]
  comments  MomentComment[]

  @@index([authorId])
  @@index([createdAt(sort: Desc)])
  @@map("moments")
}

model MomentLike {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now()) @map("created_at")
  momentId  String   @map("moment_id")
  userId    String   @map("user_id")
  moment    Moment   @relation(fields: [momentId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([momentId, userId])
  @@index([userId])
  @@map("moment_likes")
}

model MomentComment {
  id            String          @id @default(uuid())
  content       String
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")
  momentId      String          @map("moment_id")
  userId        String          @map("user_id")
  parentId      String?         @map("parent_id")
  replyToUserId String?         @map("reply_to_user_id")
  moment        Moment          @relation(fields: [momentId], references: [id], onDelete: Cascade)
  user          User            @relation("MomentCommentAuthor", fields: [userId], references: [id], onDelete: Cascade)
  replyToUser   User?           @relation("MomentCommentReplyTo", fields: [replyToUserId], references: [id], onDelete: SetNull)
  parent        MomentComment?  @relation("MomentCommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies       MomentComment[] @relation("MomentCommentReplies")

  @@index([momentId, createdAt])
  @@index([userId])
  @@map("moment_comments")
}

// ========== 成长体系（积分 / 签到 / 徽章）==========

model CheckIn {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  date      DateTime @map("date") // 归一化到当天 00:00，用于每日唯一约束
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
  @@map("check_ins")
}

model Badge {
  id          String      @id @default(uuid())
  key         String      @unique @map("key") // 例如 first_post
  name        String
  description String?
  icon        String? // emoji 图标
  awardedUsers UserBadge[]

  @@map("badges")
}

model UserBadge {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  badgeId   String   @map("badge_id")
  earnedAt  DateTime @default(now()) @map("earned_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge     Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
  @@index([userId])
  @@map("user_badges")
}

// ========== 关注关系 ==========

model Follow {
  id         String   @id @default(uuid())
  followerId String   @map("follower_id")
  followingId String   @map("following_id")
  createdAt  DateTime @default(now()) @map("created_at")
  follower   User     @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  following  User     @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
  @@map("follows")
}
