# ========== 数据库配置 ==========
DB_USER=postgres
DB_PASSWORD=<使用 openssl rand -hex 16 生成>
DB_NAME=blog_db

# ========== Redis 配置 ==========
REDIS_HOST=redis
REDIS_PORT=6379
# 生产环境建议设置密码
REDIS_PASSWORD=<使用 openssl rand -hex 8 生成>

# ========== 后端配置 ==========
SERVER_PORT=3000
JWT_SECRET=<使用 openssl rand -hex 32 生成>
JWT_EXPIRES_IN=7d

# ========== 前端配置 ==========
CLIENT_PORT=8080
# 有域名填 https://your-domain.com，无域名填 http://服务器公网IP
CLIENT_URL=https://your-domain.com
VITE_API_URL=https://your-domain.com/api/v1
